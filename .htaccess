RewriteEngine On

# Clean URLs: /lavina-house → /menu?slug=lavina-house
# /admin → admin dashboard

# Don't rewrite actual files or directories
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d

# API routes already handled by api/.htaccess

# Static menu fallback URLs: /menu/slug → menu.html?slug=slug
RewriteRule ^menu/([a-zA-Z0-9_-]+)$ menu.html?slug=$1 [QSA,L]

# Restaurant slug URLs: /slug → menu.html?slug=slug
# Only match single-segment paths that aren't reserved words
RewriteCond %{REQUEST_URI} !^/(api|admin|static|images|look|vip|includes|migrations|scratch)($|/)
RewriteRule ^([a-zA-Z0-9_-]+)$ menu.html?slug=$1 [QSA,L]

# Default: serve index.html for root
DirectoryIndex index.html
